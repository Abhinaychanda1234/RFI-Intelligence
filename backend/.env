# ===== RFI Genie Backend Configuration =====

# Server
PORT=3001
NODE_ENV=development
FRONTEND_URL=https://green-mud-0941f4810.4.azurestaticapps.net

# --- Option A: Standard OpenAI ---
OPENAI_API_KEY=

# --- Option B: Azure OpenAI (set USE_AZURE_OPENAI=true) ---
USE_AZURE_OPENAI=true
# Fill in your Azure OpenAI resource name and key below.
# Find these in Azure Portal → Azure OpenAI → Keys and Endpoint
AZURE_OPENAI_ENDPOINT=https://rfi-genie-openai.openai.azure.com/openai/deployments/gpt-4o/chat/completions?api-version=2025-01-01-preview
AZURE_OPENAI_API_KEY=FDoqxyskLLrI9eTQGTnnzwW69bDJxzRUKvrnu7lW3Cdt7tSBfRftJQQJ99CCACYeBjFXJ3w3AAABACOGzExz
AZURE_OPENAI_EMBEDDING_DEPLOYMENT=text-embedding-ada-002
AZURE_OPENAI_DEPLOYMENT=gpt-4o
AZURE_OPENAI_API_VERSION=2024-02-15-preview

# Azure Blob Storage (optional — uses local disk by default)
USE_AZURE_STORAGE=false
AZURE_STORAGE_CONNECTION_STRING=DefaultEndpointsProtocol=https;AccountName=...
AZURE_STORAGE_CONTAINER=rfi-documents

# Database
DB_PATH=./data/rfi_genie.db

# Security
JWT_SECRET=change_this_to_a_random_32_char_secret

# Admin
ADMIN_PASSWORD=admin123
